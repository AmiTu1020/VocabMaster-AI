rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidVocab(data) {
      return data.word is string && data.word.size() > 0 && data.word.size() < 500 &&
             data.translation is string && data.translation.size() > 0 && data.translation.size() < 1000 &&
             data.creatorId is string && data.creatorId == request.auth.uid &&
             data.phonetic is string && data.phonetic.size() < 200 &&
             data.keys().hasAll(['word', 'translation', 'creatorId', 'createdAt', 'phonetic']);
    }

    match /vocab/{vocabId} {
      allow read: if isSignedIn() && resource.data.creatorId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(vocabId) && 
                      isValidVocab(request.resource.data) && 
                      request.resource.data.createdAt == request.time;
      allow update: if isSignedIn() && isOwner(resource.data.creatorId) && 
                      isValidVocab(request.resource.data) &&
                      request.resource.data.createdAt == resource.data.createdAt &&
                      request.resource.data.creatorId == resource.data.creatorId &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['word', 'translation', 'phonetic', 'examples', 'grammarPoints']);
      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
  }
}
